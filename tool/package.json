  },
  "dependencies": {
    "@angular/compiler": "19.2.14",
    "ts-morph": "24.0.0"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "@vitest/coverage-v8": "2.1.8",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  }
}
